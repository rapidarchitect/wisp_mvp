# Local development backend image for WISPGen.
# Uses fake LLM/Tavily so Playwright E2E can run without external credentials.
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libsqlite3-0 \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# Install dependencies first (cache-friendly)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen

# Mount point for live source edits
VOLUME /app/src
WORKDIR /app/src

ENV WISPGEN_ENV=test
ENV WISPGEN_DATA_DIR=/app/data
ENV WISPGEN_BASE_DOMAIN=localhost
ENV LLM_PROVIDER=fake
ENV EMAIL_BACKEND=console
ENV WISPGEN_ENABLE_TEST_ENDPOINTS=true

COPY infra/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/app/docker-entrypoint.sh"]
